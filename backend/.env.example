 TASA_CRON=0 * * * *
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public"
PORT=4000
ALLOWED_ORIGINS="http://localhost:3000, http://localhost:5173, http://localhost:3001, http://localhost:4000"
NODE_ENV=development

JWT_SECRET=TU_SECRET_KEY
JWT_EXPIRES_IN=1d

# ─── Configuración SMTP (Nodemailer) ───────────────────────────────────────────
# IMPORTANTE: Gmail NO acepta tu contraseña normal. Necesitas una "Contraseña de Aplicación":
#   Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones
#   Selecciona "Correo" + tu dispositivo → copia el código de 16 caracteres → pégalo en SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=Tu_correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=Single Sales
SMTP_FROM_EMAIL=tu_correo@gmail.com

