{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": "."
  }
  ,
  "include": [
    "src/**/*",
    "prisma.config.ts",
    "prisma/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}